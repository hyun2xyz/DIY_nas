# Copy this file to .env and replace placeholders with local values.
# Do not commit .env.

NAS_PILOT_HOST=127.0.0.1
NAS_PILOT_PORT=8790
NAS_PILOT_DATA_DIR=C:\Users\<WINDOWS_USER>\nas-pilot-data
NAS_PILOT_QUOTA_BYTES=53687091200

# Optional. If omitted, the first run generates a bootstrap admin password in
# NAS_PILOT_DATA_DIR\bootstrap-admin.txt.
NAS_PILOT_ADMIN_USER=admin
# NAS_PILOT_ADMIN_PASSWORD=change-this-before-use

# Integration Gateway. External websites, LMS, wiki, or automation clients use
# this API instead of storing direct storage credentials.
NAS_GATEWAY_HOST=127.0.0.1
NAS_GATEWAY_PORT=8791
NEXTCLOUD_BASE_URL=http://<VM_HOST_OR_IP>:8080
NEXTCLOUD_USERNAME=<NEXTCLOUD_SERVICE_ACCOUNT>
# NEXTCLOUD_APP_PASSWORD=generate-this-in-nextcloud
NAS_GATEWAY_TOKENS_FILE=C:\Users\<WINDOWS_USER>\nas-cloud-secrets\gateway-tokens.json
NAS_GATEWAY_MAX_UPLOAD_BYTES=1073741824

# Password-only browser Drive UI at /drive. This is a legacy transition UI.
NAS_DRIVE_PASSWORD=change-this-before-use
NAS_DRIVE_SESSION_SECRET=generate-a-long-random-secret

# Public HTTPS Gateway URL after Cloudflare Tunnel is configured.
GATEWAY_API_BASE_URL=https://api-drive.example.com

# Human-facing FileBrowser Quantum URL.
FILEBROWSER_PUBLIC_URL=https://drive.example.com
